# Copy this to .env and fill in your values
# Leave DATABASE_URL unset to use the local SQLite fallback (~/.devlog/devlog.db)
DATABASE_URL=postgresql://localhost/devlog

# Required for `devlog summary` (AI recap of your sessions)
ANTHROPIC_API_KEY=your-key-here

# Optional: Redis for API caching (falls back gracefully if not set)
REDIS_URL=redis://localhost:6379/0
